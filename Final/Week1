<!DOCTYPE html>
<html>
<head>
<title>Beautiful House Scene</title>

<style>
body{
    margin:0;
    display:flex;
    justify-content:center;
    align-items:center;
    height:100vh;
    background:white;
}

/* Canvas Area */
.canvas{
    width:700px;
    height:450px;
    border:3px solid gray;
    position:relative;
    background:skyblue;   /* Sky Background */
    overflow:hidden;
}

/* Sun */
.sun{
    width:90px;
    height:90px;
    background:yellow;
    border-radius:50%;
    position:absolute;
    top:30px;
    left:40px;
    box-shadow:0 0 30px yellow;
}

/* Ground */
.ground{
    width:100%;
    height:140px;
    background:green;
    position:absolute;
    bottom:0;
}

/* House Body */
.house{
    width:160px;
    height:120px;
    background:#ff9966;   /* Changed House Color */
    position:absolute;
    bottom:140px;
    left:270px;
    border:2px solid #333;
}

/* Roof */
.roof{
    width:0;
    height:0;
    border-left:90px solid transparent;
    border-right:90px solid transparent;
    border-bottom:90px solid #cc0000;
    position:absolute;
    bottom:260px;
    left:260px;
}

/* Door */
.door{
    width:40px;
    height:70px;
    background:#4d2600;
    position:absolute;
    bottom:140px;
    left:330px;
}

/* Windows */
.window1, .window2{
    width:35px;
    height:35px;
    background:lightblue;   /* Changed Window Color */
    border:2px solid white;
    position:absolute;
    bottom:200px;
}

.window1{
    left:290px;
}

.window2{
    left:375px;
}
</style>
</head>

<body>

<div class="canvas">

    <!-- Sun -->
    <div class="sun"></div>

    <!-- Ground -->
    <div class="ground"></div>

    <!-- Roof -->
    <div class="roof"></div>

    <!-- House -->
    <div class="house"></div>

    <!-- Door -->
    <div class="door"></div>

    <!-- Windows -->
    <div class="window1"></div>
    <div class="window2"></div>

</div>

</body>
</html>
